<?xml version="1.0"?>
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" component="Magento_Ui/js/form/form" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">ict_loyaltytier_tier_form.ict_loyaltytier_tier_form_data_source</item>
        </item>
        <item name="label" xsi:type="string" translate="true">Tier Form</item>
        <item name="template" xsi:type="string">templates/form/collapsible</item>
    </argument>
    <settings>
        <namespace>ict_loyaltytier_tier_form</namespace>
        <dataScope>data</dataScope>
        <buttons>
            <button name="save" class="Ict\LoyaltyTier\Block\Adminhtml\Tier\Edit\Button\Save"/>
            <!-- <button name="back" class="Custommodule\Adminemp\Block\Adminhtml\Employee\Edit\Button\Back"/>
            <button name="saveedit" class="Custommodule\Adminemp\Block\Adminhtml\Employee\Edit\Button\SaveEdit"/>
            <button name="delete" class="Custommodule\Adminemp\Block\Adminhtml\Employee\Edit\Button\Delete"/> -->
        </buttons>
        <deps>
            <dep>ict_loyaltytier_tier_form.ict_loyaltytier_tier_form_data_source</dep>
        </deps>
    </settings>
    <dataSource name="ict_loyaltytier_tier_form_data_source">
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_Ui/js/form/provider</item>
            </item>
        </argument>
        <argument name="dataProvider" xsi:type="configurableObject">
            <argument name="class" xsi:type="string">
                Ict\LoyaltyTier\Model\Tier\FormDataProvider</argument>
            <argument name="name" xsi:type="string">ict_loyaltytier_tier_form_data_source</argument>
            <argument name="primaryFieldName" xsi:type="string">entity_id</argument>
            <argument name="requestFieldName" xsi:type="string">entity_id</argument>
        </argument>
        <settings>
            <submitUrl path="loyaltytier/index/save" />
        </settings>
    </dataSource>
    <fieldset name="general">
        <settings>
            <label translate="true"></label>
            <collapsible>false</collapsible>
        </settings>
        <field name="entity_id" formElement="input">
            <settings>
                <dataType>text</dataType>
                <visible>false</visible>
                <dataScope>entity_id</dataScope>
            </settings>
        </field>
       
<field name="status" formElement="checkbox">
    <settings>
        <dataType>boolean</dataType>
        <label translate="true">Status</label>
        <dataScope>status</dataScope>
    </settings>
    <formElements>
        <checkbox>
            <settings>
                <prefer>toggle</prefer>
                <valueMap>
                    <map name="false" xsi:type="number">0</map>
                    <map name="true" xsi:type="number">1</map>
                </valueMap>
            </settings>
        </checkbox>
    </formElements>
</field>

        <field name="name" formElement="input" sortOrder="10">
            <settings>
                <label translate="true">Name</label>
                <dataType>text</dataType>
                <dataScope>name</dataScope>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
            </settings>
        </field>
        <field name="discount" formElement="input" sortOrder="20">
            <settings>
                <label translate="true">Discount </label>
                <dataType>text</dataType>
                <dataScope>discount</dataScope>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
            </settings>
        </field>
         <field name="limit" formElement="input" sortOrder="20">
            <settings>
                <label translate="true">Usage limit </label>
                <dataType>text</dataType>
                <dataScope>limit</dataScope>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
            </settings>
        </field>
        <field name="minimum_spend" formElement="input" sortOrder="30">
            <settings>
                <label translate="true">Minimum Spend</label>
                <dataType>number</dataType>
                <dataScope>minimum_spend</dataScope>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                    <rule name="validate-zero-or-greater" xsi:type="boolean">true</rule>
                </validation>
            </settings>
        </field>


        <field name="image" formElement="imageUploader" sortOrder="30">
            <settings>
                <label translate="true">Profile Image</label>
                <dataType>string</dataType>
            </settings>
            <formElements>
                <imageUploader>
                    <settings>
                        <allowedExtensions>jpg jpeg png</allowedExtensions>
                        <maxFileSize>2097152</maxFileSize>
                        <uploaderConfig>
                            <param xsi:type="url" name="url" path="ict/index/upload" />
                        </uploaderConfig>
                        <previewTmpl>Magento_Catalog/image-preview</previewTmpl>
                        <openDialogTitle>Select Image</openDialogTitle>
                    </settings>
                </imageUploader>
            </formElements>

        </field>






    </fieldset>
</form>
