<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="loyalty" resource="default" engine="innodb" comment="Loyalty">
        <column xsi:type="smallint" name="entity_id" unsigned="false" nullable="false" identity="true" comment="Entity ID"/>
        <column xsi:type="smallint" name="status" unsigned="true" nullable="false" identity="false" default="0" comment="Visibility status"/>
        <column xsi:type="varchar" name="name" nullable="false" length="255" comment="Tier name"/>
        <column xsi:type="decimal" name="discount" scale="6" precision="20" unsigned="false" nullable="false" default="0" comment="Discount"/>
        <column xsi:type="smallint" name="limit" nullable="false" comment="Usage limit"/>
        <column xsi:type="decimal" name="minimum_spend" scale="6" precision="20" unsigned="false" nullable="false" default="0" comment="Minimun Spend"/>
        <column xsi:type="varchar" name="image" nullable="true" length="255" comment="Tier Image"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>
        <index referenceId="ICT_EXAM_FT_INDEX" indexType="fulltext">
            <column name="name"/>


        </index>
    </table>
    <table name="sales_order" resource="sales" engine="innodb" comment="Sales Order">
        <column xsi:type="int" name="loyalty_tier_id" nullable="true" comment="Loyalty Tier Id"/>
        <column xsi:type="varchar" name="loyalty_tier_name" nullable="true" length="255" comment="Loyalty Tier Name"/>
        <column xsi:type="decimal" name="loyalty_discount_amount" scale="6" precision="20" unsigned="false" nullable="false" default="0" comment="Loyalty Discount Amount"/>
        <column xsi:type="decimal" name="base_loyalty_discount_amount" scale="6" precision="20" unsigned="false" nullable="false" default="0" comment="Base Loyalty Discount Amount"/>
    </table>
    <table name="quote" resource="checkout" engine="innodb" comment="Sales Flat Quote">
        <column xsi:type="int" name="loyalty_tier_id" nullable="true" comment="Loyalty Tier Id"/>
        <column xsi:type="varchar" name="loyalty_tier_name" nullable="true" length="255" comment="Loyalty Tier Name"/>
        <column xsi:type="decimal" name="loyalty_discount_amount" scale="6" precision="20" unsigned="false" nullable="false" default="0" comment="Loyalty Discount Amount"/>
        <column xsi:type="decimal" name="base_loyalty_discount_amount" scale="6" precision="20" unsigned="false" nullable="false" default="0" comment="Base Loyalty Discount Amount"/>
    </table>
    <!-- <table name="customer_grid_flat" resource="default" engine="innodb">
        <column xsi:type="varchar" name="loyalty_tier"  nullable="false"  comment="Loyalty Tier"/>
        <column xsi:type="varchar" name="lifetime_spend"  nullable="false"  comment="Lifetime Spend"/>
    </table> -->

</schema>
