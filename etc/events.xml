<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Event/etc/events.xsd">
    <event name="sales_order_shipment_save_after">
        <observer name="Ict_LoyaltyTier_shipment_save_after" instance="Ict\LoyaltyTier\Observer\ShipmentSaveAfter" />
    </event>
    <event name="sales_model_service_quote_submit_before">
        <observer name="Ict_LoyaltyTier_copy_quote_loyalty_to_order" instance="Ict\LoyaltyTier\Observer\CopyQuoteLoyaltyDataToOrder" />
    </event>
    <event name="sales_convert_quote_to_order">
        <observer name="Ict_LoyaltyTier_copy_quote_loyalty_on_convert" instance="Ict\LoyaltyTier\Observer\CopyQuoteLoyaltyDataToOrder" />
    </event>
    <event name="sales_model_service_quote_submit_success">
        <observer name="Ict_LoyaltyTier_sync_customer_loyalty_after_quote_submit" instance="Ict\LoyaltyTier\Observer\SyncCustomerLoyaltyAfterOrderChange" />
    </event>
    <event name="order_cancel_after">
        <observer name="Ict_LoyaltyTier_sync_customer_loyalty_after_order_cancel" instance="Ict\LoyaltyTier\Observer\SyncCustomerLoyaltyAfterOrderChange" />
    </event>
    <event name="sales_order_save_after">
        <observer name="Ict_LoyaltyTier_sync_customer_loyalty_after_order_save" instance="Ict\LoyaltyTier\Observer\SyncCustomerLoyaltyAfterOrderChange" />
    </event>
    <event name="sales_order_save_commit_after">
        <observer name="Ict_LoyaltyTier_sync_customer_loyalty_after_order_commit" instance="Ict\LoyaltyTier\Observer\SyncCustomerLoyaltyAfterOrderChange" />
    </event>
</config>
